#:import dp kivy.metrics.dp

<CalcButton@Button>:
    background_normal: ""
    background_color: (0.18,0.19,0.28,1)
    color: 1,1,1,1
    font_size: "22sp"
    canvas.before:
        Color:
            rgba: self.background_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [20]

<OperatorButton@Button>:
    background_normal: ""
    background_color: (0.95,0.60,0.05,1)
    color: 1,1,1,1
    font_size: "24sp"
    bold: True
    canvas.before:
        Color:
            rgba: self.background_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [20]



BoxLayout:
    orientation: "vertical"
    padding: dp(20)
    spacing: dp(15)

    canvas.before:
        Color:
            rgba: (0.08,0.09,0.15,1)
        Rectangle:
            pos: self.pos
            size: self.size

    # DISPLAY AREA
    BoxLayout:
        orientation: "vertical"
        size_hint_y: .35
        padding: dp(10)

        Label:
            id: expression
            text: app.engine.expression
            color: .7,.7,.8,1
            font_size: "20sp"
            halign: "right"
            valign: "middle"
            text_size: self.size

        Label:
            id: display
            text: "0"
            color: 1,1,1,1
            font_size: "48sp"
            bold: True
            halign: "right"
            valign: "middle"
            text_size: self.size

    # BUTTON GRID
    GridLayout:
        cols: 4
        spacing: dp(12)
        size_hint_y: .65

    
        CalcButton:
            text: "⌫"
            on_press: app.on_button(self.text)

        CalcButton:
            text: "C"
            on_press:
                app.engine.clear()
                app.root.ids.display.text = "0"
                app.root.ids.expression.text = ""

        CalcButton:
            text: "+/-"
            on_press: app.on_button(self.text)

        CalcButton:
            text: "%"
            on_press: app.on_button(self.text)

        OperatorButton:
            text: "÷"
            on_press: app.on_button("/")

        CalcButton:
            text: "7"
            on_press: app.on_button(self.text)

        CalcButton:
            text: "8"
            on_press: app.on_button(self.text)

        CalcButton:
            text: "9"
            on_press: app.on_button(self.text)

        OperatorButton:
            text: "x"
            on_press: app.on_button("*")

        CalcButton:
            text: "4"
            on_press: app.on_button(self.text)

        CalcButton:
            text: "5"
            on_press: app.on_button(self.text)

        CalcButton:
            text: "6"
            on_press: app.on_button(self.text)

        OperatorButton:
            text: "-"
            on_press: app.on_button(self.text)

        CalcButton:
            text: "1"
            on_press: app.on_button(self.text)

        CalcButton:
            text: "2"
            on_press: app.on_button(self.text)

        CalcButton:
            text: "3"
            on_press: app.on_button(self.text)

        OperatorButton:
            text: "+"
            on_press: app.on_button(self.text)

        CalcButton:
            text: "0"
            size_hint_x: 2
            on_press: app.on_button(self.text)

        CalcButton:
            text: "."
            on_press: app.on_button(self.text)

        OperatorButton:
            text: "="
            on_press: app.on_button(self.text)